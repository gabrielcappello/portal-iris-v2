# Copie para .env.local e preencha (NÃO comitar o .env.local real).
# A URL do Supabase e a chave anon estão hardcoded em src/lib/supabase.ts.
# Aqui ficam só as chaves de SERVIDOR (lidas em runtime nas rotas /api).

# Chave secreta do Supabase (service role). Necessária para o odontograma e o
# financeiro funcionarem local (proxy /api/odontograma). Preferir a de STAGING.
SUPABASE_SECRET=
# Compat: usada se SUPABASE_SECRET não estiver setada.
SUPABASE_SERVICE_KEY=

# Recuperação de senha (Resend)
RESEND_API_KEY=
APP_URL=http://localhost:3000

# Proxies n8n (opcionais para dev local do calendário/remarcação/chat)
N8N_BUSCAR_CALENDARIO_URL=
N8N_REMARCACAO_MASSA_URL=
N8N_ENVIAR_MENSAGEM_MANUAL_URL=
